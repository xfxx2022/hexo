{
  "headers": [
    {
      "source": "/(.*)\\.(js|css|woff2?|ttf|eot|svg|webp|avif|png|jpe?g|gif|ico|mp4|webm|ogg|mp3|json|xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
